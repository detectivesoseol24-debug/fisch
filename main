    renderTradeContent(t.dataset.ttab);
  }));
  // shop refreshes every 15 min
  setInterval(()=>{
    const cur=Math.floor(Date.now()/900000);
    if(cur!==S.shopTimer){S.shopTimer=cur;S.shopPurchased={};buildShop15();toast('🕐 Shop refreshed!');}
    else buildShop15();
  },30000);
  buildShop15();
  // update area bg on load
  updateAreaBg(S.currentArea);
  buildShop15();
  if(currentUser===OWNER)setupAdminPanel();
  // check for active global event
  const ge=getGEV();
  if(ge&&Date.now()<ge.endsAt){const r=Math.round((ge.endsAt-Date.now())/1000);S.event=ge.type;S.eventTimer=r;_applyEventVisuals(ge.type);}
}

