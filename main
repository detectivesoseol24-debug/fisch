function getExpForFish(fish,mut){
  const rarExp={common:5,uncommon:10,rare:25,legendary:60,mythic:150,exotic:350,secret:800,divine:2000};
  let exp=rarExp[fish.rarity]||5;
  if(mut.id!=='normal')exp=Math.round(exp*(1+mut.pMul*0.1));
  // Potion bonus
  if(S.potions?.xpBoost?.active&&Date.now()<S.potions.xpBoost.endsAt)exp*=2;
  // Rod bonus
  if(S.currentRod==='eternrod')exp=Math.round(exp*1.5);
  if(S.currentRod==='legendrod')exp*=2;
  return exp;
}

function addExp(amount){
  S.exp+=amount;
  let leveled=false;
  while(S.exp>=getExpNeeded(S.level)&&S.level<100){
    S.exp-=getExpNeeded(S.level);S.level++;leveled=true;
    checkLevelRewards(S.level);
    checkTitleUnlocks();
  }
  if(leveled){
    toast('🎉 Level Up! Now Level '+S.level+'!');
    playEvSound('aurora');
  }
  updateHUD();
}

const LEVEL_REWARDS={
  5:   {gold:500,   desc:'500g'},
  10:  {gold:2000,  bait:{id:'magic',qty:5},   desc:'2000g + Magic Bait ×5'},
  15:  {gold:5000,  desc:'5000g'},
  20:  {gold:10000, item:'bloodtotem',          desc:'10000g + Blood Moon Totem'},
  25:  {gold:20000, bait:{id:'void',qty:3},     desc:'20000g + Void Bait ×3'},
  30:  {gold:50000, item:'auroratotem',         desc:'50000g + Aurora Totem'},
  35:  {gold:100000,desc:'100000g'},
  40:  {gold:200000,bait:{id:'omega',qty:2},    desc:'200000g + Omega Bait ×2'},
  50:  {gold:500000,item:'meteortotem',bait:{id:'radiant_bait',qty:1},desc:'500000g + Meteor Totem + Radiant Lure'},
  60:  {gold:1000000,desc:'1,000,000g'},
  75:  {gold:5000000,desc:'5,000,000g'},
  100: {gold:99999999,desc:'INFINITE GOLD!'},
};

function checkLevelRewards(lvl){
  const r=LEVEL_REWARDS[lvl];if(!r)return;
  if(r.gold){S.gold+=r.gold;}
  if(r.bait){S.baitInventory[r.bait.id]=(S.baitInventory[r.bait.id]||0)+r.bait.qty;}
  if(r.item){S.items[r.item]=(S.items[r.item]||0)+1;}
  toast('🎁 Level '+lvl+' reward: '+r.desc+'!');
}

function checkTitleUnlocks(){
  TITLES.forEach(t=>{
    if(S.ownedTitles.includes(t.id))return;
    let unlock=false;
    if(t.minLevel&&S.level>=t.minLevel)unlock=true;
    if(t.special==='megalodon'&&S.caughtFishIds.has('megalodon'))unlock=true;
    if(t.special==='leviathan'&&S.caughtFishIds.has('leviathan'))unlock=true;
    if(t.special==='firstcatch'&&S.totalCatches>=1)unlock=true;
    if(t.specialCount==='mutations'&&S.mutationsCaught>=t.target)unlock=true;
    if(t.specialArea&&(S.areaCatches||{})[t.specialArea]>=(t.target||1))unlock=true;
    if(unlock){S.ownedTitles.push(t.id);toast('🏆 New Title Unlocked: '+t.id+'!');}
  });
}

