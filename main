// ═══════════════════════════════════════════════
//  QUESTS
// ═══════════════════════════════════════════════
function tickQ(){
  const all=[...S.quests.daily,...S.quests.weekly,...S.quests.main,...S.quests.rod,...S.quests.item];
  all.filter(q=>!q.claimed).forEach(q=>{
    switch(q.type){
      case 'catches':      q.progress=Math.min(q.target,S.totalCatches);break;
      case 'gold':         q.progress=Math.min(q.target,S.totalGoldEarned);break;
      case 'species':      q.progress=Math.min(q.target,S.caughtFishIds.size);break;
      case 'mutation':     q.progress=Math.min(q.target,S.mutationsCaught);break;
      case 'bloodcatch':   q.progress=Math.min(q.target,S.bloodCatches);break;
      case 'auroracatch':  q.progress=Math.min(q.target,S.auroraCatches);break;
      case 'rarecatch':    q.progress=Math.min(q.target,S.rareCatches);break;
      case 'areas':        q.progress=Math.min(q.target,S.areasVisited.size);break;
      case 'legcount':     q.progress=Math.min(q.target,S.legCount);break;
      case 'mythiccatch':  q.progress=Math.min(q.target,S.mythicCatches);break;
      case 'prismatic':    q.progress=Math.min(q.target,S.prismaticCaught);break;
      case 'goldenmut':    q.progress=Math.min(q.target,S.goldenMutCaught);break;
      case 'darkmut':      q.progress=Math.min(q.target,S.darkMutCaught);break;
      case 'elitequest':   q.progress=Math.min(q.target,S.mythicCatches);break;
      case 'blizzcatch':   q.progress=Math.min(q.target,S.blizzCatches);break;
      case 'eventcatch':   q.progress=Math.min(q.target,S.eventsEncountered.size);break;
    }
  });
}
function qDone(q){
  if(q.type==='rarity'||q.type==='area')return(q.progress||0)>=1;
  const t=q.questCount||q.target;return(q.progress||0)>=t;
}
function checkBadges(){
  const all=[...S.quests.daily,...S.quests.weekly,...S.quests.main,...S.quests.rod,...S.quests.item];
  document.getElementById('quest-badge').style.display=all.some(q=>!q.claimed&&qDone(q))?'inline-block':'none';
}
function renderQuests(){
  const list=document.getElementById('quest-list');list.innerHTML='';
  const pool=S.quests[S.questTab]||[];
  pool.forEach(q=>{
    const done=qDone(q),prog=q.progress||0;
    const t=q.questCount||q.target;
    let pct=q.type==='rarity'||q.type==='area'?prog>=1?100:0:Math.min(100,Math.round(prog/t*100));
    const div=document.createElement('div');
    div.className=`qcard ${q.weekly?'weekly':''} ${done&&!q.claimed?'done':''} ${q.claimed?'claimed':''}`;
    let rlabel='';
    if(q.itemR){
      if(q.itemR.type==='rod'){const r=RODS.find(x=>x.id===q.itemR.id);rlabel=`🎣 ${r?r.icon+' '+r.name:'Rod'}`;}
      else{const n=q.itemR.id==='bloodtotem'?'Blood Totem':q.itemR.id==='auroratotem'?'Aurora Totem':q.itemR.id==='stormtotem'?'Storm Totem':'Meteor Totem';rlabel=`🎁 ${n} x${q.itemR.qty}`;}
    } else rlabel=`🏆 ${q.reward.toLocaleString()}g`;
    div.innerHTML=`<div class="qname">${q.name}</div><div class="qdesc">${q.desc}</div><div class="qpw"><div class="qpb" style="width:${pct}%"></div></div><div class="qfooter"><span class="qreward ${q.itemR?'item-r':''}">${rlabel}</span><button class="qclaim" ${done&&!q.claimed?'':'disabled'}>${q.claimed?'✓ Done':done?'Claim!':'...'}</button></div>`;
    if(done&&!q.claimed)div.querySelector('.qclaim').addEventListener('click',()=>claimQ(q));
    list.appendChild(div);
  });
}
function claimQ(q){
  if(q.goldCost&&S.gold<q.goldCost){toast('Need '+q.goldCost.toLocaleString()+'g to claim this quest!');return;}
  if(q.goldCost){S.gold-=q.goldCost;updateHUD();}
  q.claimed=true;
  if(q.itemR){
    if(q.itemR.type==='rod'){const r=RODS.find(x=>x.id===q.itemR.id);if(r&&!S.ownedRods.includes(r.id)){S.ownedRods.push(r.id);S.currentRod=r.id;}toast('🎣 Got '+r.icon+' '+r.name+'!');}
    else{S.items[q.itemR.id]=(S.items[q.itemR.id]||0)+(q.itemR.qty||1);const n=q.itemR.id==='bloodtotem'?'Blood Totem':q.itemR.id==='auroratotem'?'Aurora Totem':q.itemR.id==='stormtotem'?'Storm Totem':'Meteor Totem';toast('🎁 Got '+n+'!');}
  } else {S.gold+=q.reward;toast('🏆 "'+q.name+'" done! +'+q.reward.toLocaleString()+'g');}
  updateHUD();renderQuests();checkBadges();saveGame();
}

// ═══════════════════════════════════════════════
//  COLLECTION
// ═══════════════════════════════════════════════
function renderTitles(){
  const grid=document.getElementById('titles-grid');if(!grid)return;grid.innerHTML='';
  TITLES.forEach(t=>{
    const owned=(S.ownedTitles||[]).includes(t.id);
    const active=S.title===t.id;
    const c=t.color||'#aaa';
    const d=document.createElement('div');
    d.className='title-card'+(owned?' owned':'  locked')+(active?' active-title':'');
    d.style.borderColor=active?c:owned?c+'44':'rgba(255,255,255,.06)';
    d.style.background=active?c+'18':owned?'rgba(255,255,255,.03)':'rgba(255,255,255,.01)';
    const req=t.minLevel?'Lv.'+t.minLevel:t.special?'Special catch':t.specialCount?t.target+' mutations':t.specialArea?t.target+'× '+t.specialArea:'—';
    d.innerHTML=`<div class="title-name" style="color:${owned?c:'rgba(255,255,255,.3)'}">${owned?t.id:'???'}</div><div class="title-meta">${t.rarity}</div><div class="title-meta" style="color:${c}44">${req}</div>${active?'<div class="title-meta" style="color:'+c+'">✓ Equipped</div>':''}`;
    if(owned)d.addEventListener('click',()=>{S.title=t.id;saveGame();renderTitles();updateHUD();toast('🏆 Title: '+t.id);});
    grid.appendChild(d);
  });
}

function renderCollection(){
  const grid=document.getElementById('col-grid');grid.innerHTML='';
  FISH_DB.forEach(f=>{
    const caught=S.caughtFishIds.has(f.id);
    const div=document.createElement('div');
    div.className=`ccard ${caught?'caught':''} ${caught&&['exotic','secret','divine'].includes(f.rarity)?f.rarity:''}`;
    div.innerHTML=`<div class="cicon">${caught?f.icon:'❓'}</div><div class="cname">${caught?f.name:'???'}</div>`;
    if(caught){
      div.addEventListener('mouseenter',e=>showFishDetailPopup(f,e));
      div.addEventListener('mouseleave',()=>hideFishDetailPopup());
      div.addEventListener('mousemove',e=>moveFishDetailPopup(e));
    }
    grid.appendChild(div);
  });
  document.getElementById('coll-count').textContent=S.caughtFishIds.size+' / '+FISH_DB.length;
}


// ═══════════════════════════════════════════════
//  FISH DETAIL POPUP
// ═══════════════════════════════════════════════
const RARITY_COLORS={common:'#a0b0c0',uncommon:'#44cc88',rare:'#4488ff',legendary:'#cc44ff',mythic:'#ff8844',exotic:'#ff44aa',secret:'#ffe066',divine:'#ffffff'};
function showFishDetailPopup(fish,e){
  const pop=document.getElementById('fish-detail-popup');
  const log=S.fishLog[fish.id];
  const caught=S.caughtFishIds.has(fish.id);
  document.getElementById('fdp-icon').textContent=fish.icon;
  document.getElementById('fdp-name').textContent=fish.name;
  const rc=document.getElementById('fdp-rarity');
  rc.textContent=fish.rarity[0].toUpperCase()+fish.rarity.slice(1);
  rc.style.background=(RARITY_COLORS[fish.rarity]||'#fff')+'22';
  rc.style.color=RARITY_COLORS[fish.rarity]||'#fff';
  rc.style.border='1px solid '+(RARITY_COLORS[fish.rarity]||'#fff')+'55';
  const rows=document.getElementById('fdp-rows');
  rows.innerHTML='';
  const add=(l,v)=>{const r=document.createElement('div');r.className='fdp-row';r.innerHTML=`<span class="fdp-label">${l}</span><span class="fdp-val">${v}</span>`;rows.appendChild(r);};
  add('Area',AREAS.find(a=>a.id===fish.area)?.name||fish.area);
  add('Base Value',fish.price.toLocaleString()+'g');
  add('Size Range',fish.min+'–'+fish.max+'cm');
  if(caught&&log){
    add('Times Caught',log.count.toLocaleString());
    add('Biggest Size',log.biggestSize+'cm / '+(log.biggestWeight||'?')+'kg');
    add('Best Value',log.biggestValue.toLocaleString()+'g');
    const fc=document.getElementById('fdp-first');
    fc.textContent='First caught: '+new Date(log.firstCaught).toLocaleDateString();
  } else {
    document.getElementById('fdp-first').textContent=caught?'Discovered!':'Not yet caught';
  }
  pop.classList.add('show');
  moveFishDetailPopup(e);
}
function moveFishDetailPopup(e){
  const pop=document.getElementById('fish-detail-popup');
  let x=e.clientX+14,y=e.clientY+14;
  if(x+270>window.innerWidth)x=e.clientX-274;
  if(y+250>window.innerHeight)y=e.clientY-254;
  pop.style.left=x+'px';pop.style.top=y+'px';
}
function hideFishDetailPopup(){document.getElementById('fish-detail-popup').classList.remove('show');}

