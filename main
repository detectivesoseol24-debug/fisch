  document.querySelectorAll('#quest-tabs .tbtn').forEach(t=>t.addEventListener('click',()=>{S.questTab=t.dataset.qtab;document.querySelectorAll('#quest-tabs .tbtn').forEach(x=>x.classList.remove('active'));t.classList.add('active');renderQuests();}));
  document.addEventListener('keydown',e=>{if(e.code==='Space'){e.preventDefault();MG.holding=true;}});
  document.addEventListener('keyup',  e=>{if(e.code==='Space')MG.holding=false;});
