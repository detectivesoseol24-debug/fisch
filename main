  if(!S.inventory.length){container.innerHTML='<div style="color:var(--td);font-style:italic;font-size:12px">No fish to appraise!</div>';return;}
  container.innerHTML=`<div style="display:flex;gap:12px;width:100%;max-width:680px;flex-wrap:wrap;">
    <div style="flex:1;min-width:200px">
      <div class="ptitle">Select Fish to Appraise</div>
      <div id="app-fish-list" style="max-height:50vh;overflow-y:auto;display:flex;flex-direction:column;gap:4px;"></div>
    </div>
    <div class="appraise-result" id="app-result"><div style="color:var(--td);font-size:11px;font-style:italic">Select a fish to appraise it</div></div>
  </div>`;
  const fl=document.getElementById('app-fish-list');
  S.inventory.forEach((c,i)=>{
    const div=document.createElement('div');div.className='inv-fish rarity-'+c.fish.rarity;div.style.cursor='pointer';div.style.marginBottom='2px';
    const lbl=(c.mut.id!=='normal'?c.mut.name+' ':'')+c.fish.name;
    div.innerHTML=`<div class="if-icon">${c.fish.icon}</div><div class="if-info"><div class="if-name">${lbl}</div><div class="if-sub">${c.size}cm · ${c.value.toLocaleString()}g</div></div>`;
    div.addEventListener('click',()=>{document.querySelectorAll('#app-fish-list .inv-fish').forEach(d=>d.style.borderColor='');div.style.borderColor='var(--tg)';showAppraisal(c);});
    fl.appendChild(div);
  });
}
function showAppraisal(c){
  const tier=APPRAISE_TIERS.find(t=>c.value>=t.min&&c.value<=t.max)||APPRAISE_TIERS[0];
  const mut=c.mut;const fish=c.fish;
  const rarityColor=RARITY_COLORS[fish.rarity]||'#fff';
  const rarNames=['common','uncommon','rare','legendary','mythic','exotic','secret','divine'];
  const rarIdx=rarNames.indexOf(fish.rarity);
  const rarBar=rarNames.map((_,i)=>`<div style="flex:1;height:6px;border-radius:2px;background:${i<=rarIdx?rarityColor:'rgba(255,255,255,.08)'}"></div>`).join('');
  const res=document.getElementById('app-result');
  res.innerHTML=`
    <div class="appraise-fish-icon">${fish.icon}</div>
    <div class="appraise-title">${mut.name?mut.name+' ':''}<span style="color:${rarityColor}">${fish.name}</span></div>
    <div style="font-size:9px;letter-spacing:2px;color:${rarityColor};margin-bottom:8px">${fish.rarity.toUpperCase()}</div>
    <div style="display:flex;gap:3px;margin-bottom:10px">${rarBar}</div>
    <div style="font-size:24px;margin-bottom:4px">${tier.icon}</div>
    <div style="font-family:'Cinzel',serif;font-size:13px;color:var(--gold);margin-bottom:6px">${tier.label}</div>
    <div class="appraise-desc">${tier.desc}</div>
    ${mut.id!=='normal'?`<div style="margin-top:8px;font-size:10px;color:${mut.color||'#aaa'}">✨ ${mut.name} mutation (×${mut.pMul} value)</div>`:''}
    <div style="margin-top:8px;font-size:11px;color:var(--gold);font-family:'Cinzel',serif">${c.value.toLocaleString()} Gold</div>
    <div style="font-size:9px;color:var(--td);margin-top:3px">${c.size}cm · ${c.weight}kg</div>`;
}

// CONVERT TAB
function renderConvert(container){
  container.innerHTML=`<div style="display:flex;flex-direction:column;gap:7px;max-width:560px;width:100%;max-height:55vh;overflow-y:auto;" id="conv-list"></div>`;
  const cl=document.getElementById('conv-list');
  CONVERT_RECIPES.forEach(rec=>{
    const available=S.inventory.filter(c=>c.fish.rarity===rec.costFish).length;
    const canDo=available>=rec.costQty;
    const div=document.createElement('div');div.className='trade-card';
    const rwd=rec.rewardType==='bait'?`${BAITS.find(b=>b.id===rec.rewardId)?.icon||'?'} ${rec.rewardQty}×${BAITS.find(b=>b.id===rec.rewardId)?.name||rec.rewardId}`
      :rec.rewardType==='gold'?`💰 +${rec.rewardVal}g`
      :`🎁 ${rec.rewardId==='auroratotem'?'Aurora Totem':rec.rewardId==='bloodtotem'?'Blood Moon Totem':'Item'}`;
    div.innerHTML=`<div style="display:flex;align-items:center;gap:10px">
      <div style="font-size:22px">${rec.icon}</div>
      <div style="flex:1">
        <div style="font-family:'Cinzel',serif;font-size:10px">${rec.name}</div>
        <div style="font-size:9px;color:var(--td)">${rec.desc}</div>
        <div style="font-size:9px;margin-top:3px">Cost: <span style="color:${canDo?'var(--grn)':'var(--red)'}">×${rec.costQty} ${rec.costFish} fish</span> (have ${available}) → <span style="color:var(--gold)">${rwd}</span></div>
      </div>
      <button class="trade-exec" style="font-size:9px;padding:6px 14px" ${canDo?'':'disabled'}>Trade</button>
    </div>`;
    if(canDo)div.querySelector('.trade-exec').addEventListener('click',()=>executeConvert(rec));
    cl.appendChild(div);
  });
}
function executeConvert(rec){
  let removed=0;
  S.inventory=S.inventory.filter(c=>{if(c.fish.rarity===rec.costFish&&removed<rec.costQty){removed++;return false;}return true;});
  if(rec.rewardType==='bait'){S.baitInventory[rec.rewardId]=(S.baitInventory[rec.rewardId]||0)+rec.rewardQty;S.currentBait=rec.rewardId;toast('♻️ Converted! Got '+rec.rewardQty+'× bait!');}
  else if(rec.rewardType==='gold'){S.gold+=rec.rewardVal;toast('♻️ Converted! Got +'+rec.rewardVal+'g!');}
  else if(rec.rewardType==='item'){S.items[rec.rewardId]=(S.items[rec.rewardId]||0)+1;toast('♻️ Converted! Got totem!');}
  renderInventory();updateHUD();saveGame();renderTradeContent('convert');
}

// ═══════════════════════════════════════════════
//  UTILS
// ═══════════════════════════════════════════════
// ── FISH DETAIL POPUP ──
function showFishPopup(fish,e){
  const el=document.getElementById('fish-popup');if(!el)return;
  const log=S.fishLog?.[fish.id];
  const caught=S.caughtFishIds.has(fish.id);
  const rc=RCOLS[fish.rarity]||'#fff';
  document.getElementById('fpp-icon').textContent=fish.icon;
  document.getElementById('fpp-name').textContent=fish.name;
  const rEl=document.getElementById('fpp-rar');
  rEl.textContent=fish.rarity.toUpperCase();
  rEl.style.background=rc+'22';rEl.style.color=rc;rEl.style.border='1px solid '+rc+'44';
  const rows=document.getElementById('fpp-rows');rows.innerHTML='';
  const add=(l,v)=>{const r=document.createElement('div');r.className='fpp-row';r.innerHTML=`<span class="fpp-lbl">${l}</span><span class="fpp-val">${v}</span>`;rows.appendChild(r);};
  add('Area',AREAS.find(a=>a.id===fish.area)?.name||fish.area);
  add('Base Value',fish.price.toLocaleString()+'g');
  add('Size',fish.min+'–'+fish.max+'cm');
  if(caught&&log){
    add('Caught',log.count+'×');
    add('Biggest',log.biggestSize+'cm / '+(log.biggestWeight||'?')+'kg');
    add('Best Value',log.biggestValue.toLocaleString()+'g');
    document.getElementById('fpp-hint').textContent='First: '+new Date(log.firstCaught).toLocaleDateString();
  } else {
    document.getElementById('fpp-hint').textContent=caught?'Discovered!':'Not yet caught';
  }
  el.classList.add('on');
  moveFishPopup(e);
}
function moveFishPopup(e){
  const el=document.getElementById('fish-popup');if(!el)return;
  let x=e.clientX+12,y=e.clientY+12;
  if(x+260>window.innerWidth)x=e.clientX-264;
  if(y+230>window.innerHeight)y=e.clientY-234;
  el.style.left=x+'px';el.style.top=y+'px';
}
function hideFishPopup(){const el=document.getElementById('fish-popup');if(el)el.classList.remove('on');}

function resetIdle(){
  S.phase='idle';
  document.getElementById('cast-btn').disabled=false;
  document.getElementById('cast-hint').style.display='flex';
  document.getElementById('fail').classList.remove('active');
  resetLine();setStatus('Cast your line!');
}
function setStatus(m){document.getElementById('status-msg').textContent=m;}
let toastT;
function toast(msg){
  const el=document.getElementById('toast');el.textContent=msg;el.classList.add('show');
  clearTimeout(toastT);toastT=setTimeout(()=>el.classList.remove('show'),2800);
}

// ═══════════════════════════════════════════════
//  ADMIN PANEL
// ═══════════════════════════════════════════════
function setupAdminPanel(){
  const sel=document.getElementById('adm-ev-sel');
  if(!sel)return;
  sel.innerHTML='';
  Object.entries(EVENTS).forEach(([k,e])=>{const o=document.createElement('option');o.value=k;o.textContent=e.icon+' '+e.name;sel.appendChild(o);});
  document.getElementById('adm-start-ev')?.addEventListener('click',()=>{
    const type=sel.value,dur=parseInt(document.getElementById('adm-ev-dur')?.value)||120;
    if(!EVENTS[type])return;
    if(S.event)_endEventLocal();
    setGEV(type,dur);
    startEvent(type,false);
    const st=document.getElementById('adm-ev-st');
    if(st)st.textContent='✅ "'+EVENTS[type].name+'" started globally ('+dur+'s)';
    toast('👑 Admin broadcast: '+EVENTS[type].name+'!');
  });
  document.getElementById('adm-stop-ev')?.addEventListener('click',()=>{
    clearGEV();endEvent();
    const st=document.getElementById('adm-ev-st');if(st)st.textContent='⛔ Event stopped globally.';
    toast('👑 Admin: Event stopped.');
  });
  document.getElementById('adm-add-gold')?.addEventListener('click',()=>{
    const amt=parseInt(document.getElementById('adm-gold-amt')?.value)||0;
    if(amt<=0)return;
    S.gold+=amt;updateHUD();saveGame();
    const st=document.getElementById('adm-gold-st');if(st)st.textContent='✅ +'+amt.toLocaleString()+'g added! Total: '+S.gold.toLocaleString()+'g';
    toast('👑 +'+amt.toLocaleString()+'g!');
  });
  document.getElementById('adm-rst-gold')?.addEventListener('click',()=>{
    S.gold=200;updateHUD();saveGame();
    const st=document.getElementById('adm-gold-st');if(st)st.textContent='✅ Gold reset to 200g.';
  });
  document.getElementById('admin-ov-close')?.addEventListener('click',()=>closeOv('admin-ov'));
  // Level controls
  document.getElementById('adm-set-level')?.addEventListener('click',()=>{
    const lvl=parseInt(document.getElementById('adm-level-set')?.value)||1;
    S.level=Math.max(1,Math.min(100,lvl));S.exp=0;checkTitleUnlocks();updateHUD();saveGame();
    const st=document.getElementById('adm-lv-st');if(st)st.textContent='✅ Level set to '+S.level;
    toast('👑 Admin: Level set to '+S.level+'!');
  });
  document.getElementById('adm-add-level')?.addEventListener('click',()=>{
    if(S.level<100){S.level++;S.exp=0;checkLevelRewards(S.level);checkTitleUnlocks();updateHUD();saveGame();}
    const st=document.getElementById('adm-lv-st');if(st)st.textContent='✅ Now Level '+S.level;
    toast('👑 +1 Level! Now Lv.'+S.level);
  });
  document.getElementById('adm-add-exp')?.addEventListener('click',()=>{
    const amt=parseInt(document.getElementById('adm-exp-amt')?.value)||0;
    addExp(amt);saveGame();
    const st=document.getElementById('adm-lv-st');if(st)st.textContent='✅ Added '+amt+' EXP';
  });
}

