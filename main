  document.addEventListener('mouseup',()=>MG.holding=false);
  document.getElementById('tz-wrap').addEventListener('touchstart',e=>{e.preventDefault();MG.holding=true;});
  document.addEventListener('touchend',()=>MG.holding=false);
  document.getElementById('trade-btn').addEventListener('click',()=>openTrade());
  document.getElementById('titles-btn')?.addEventListener('click',()=>{renderTitles();openOv('titles-ov');});
  document.getElementById('titles-close')?.addEventListener('click',()=>closeOv('titles-ov'));
