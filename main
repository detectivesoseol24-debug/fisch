const TUT_STEPS=[
  {title:'Welcome to FISCH',   icon:'🎣', text:'Welcome, fisher! FISCH is an ocean fishing game where you explore areas, catch fish, and upgrade your gear. Let\'s learn the basics!'},
  {title:'Casting Your Rod',   icon:'🌊', text:'Click the water scene or the "Cast Rod" button to throw your line. Wait for a bite — the bobber will start bouncing!'},
  {title:'The Minigame',       icon:'⚡', text:'When a fish bites, the reeling minigame starts. Hold SPACE or click+hold the tension bar. Keep the golden indicator inside the GREEN zone until the progress bar fills up!'},
  {title:'Areas & Rarity',     icon:'🗺️', text:'Different areas have different fish. Rarity goes: Common → Uncommon → Rare → Legendary → Mythic → Exotic → Secret → Divine. Better rods = higher luck = rarer fish!'},
  {title:'Events & Weather',   icon:'🌈', text:'Random weather events occur! Aurora gives 10× Luck, Blood Moon doubles Mythic chance, Thunder creates Electric mutant fish, and much more. Use Totems to trigger events!'},
  {title:'Auto Fishing',       icon:'🤖', text:'Buy an Auto Fisher from the Shop to fish automatically! Perfect for grinding. Open Shop → Auto Fish tab. Your progress is always saved. Good luck, fisher!'},
];
let tutStep=0;

function showTutorial(){
  tutStep=0;
  document.getElementById('tutorial-overlay').classList.add('active');
  renderTutStep();
}
function renderTutStep(){
  const s=TUT_STEPS[tutStep];
  document.getElementById('tut-step').textContent='Step '+(tutStep+1)+' / '+TUT_STEPS.length;
  document.getElementById('tut-title').textContent=s.title;
  document.getElementById('tut-icon').textContent=s.icon;
  document.getElementById('tut-text').textContent=s.text;
  const dots=document.getElementById('tut-dots'); dots.innerHTML='';
  TUT_STEPS.forEach((_,i)=>{
    const d=document.createElement('div'); d.className='tut-dot'+(i===tutStep?' active':'');
    dots.appendChild(d);
  });
  document.getElementById('tut-next').textContent=tutStep===TUT_STEPS.length-1?'Start Fishing! 🎣':'Next →';
}
function setupTutorial(){
  document.getElementById('tut-next').addEventListener('click',()=>{
    if(tutStep<TUT_STEPS.length-1){tutStep++;renderTutStep();}
    else document.getElementById('tutorial-overlay').classList.remove('active');
  });
  document.getElementById('tut-skip').addEventListener('click',()=>document.getElementById('tutorial-overlay').classList.remove('active'));
}

