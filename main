const POTIONS=[
  {id:'luck_potion',   name:'Luck Potion',     icon:'🍀',desc:'Luck ×3 for 5 min',       price:3000, dur:300, type:'luckBoost'},
  {id:'xp_potion',     name:'XP Potion',       icon:'⚗️',desc:'2× EXP for 5 min',        price:2500, dur:300, type:'xpBoost'},
  {id:'speed_potion',  name:'Speed Potion',    icon:'⚡',desc:'Auto-fish 2× faster for 3 min',price:4000,dur:180,type:'speedBoost'},
  {id:'double_potion', name:'Double Potion',   icon:'🪄',desc:'2× items per auto-catch for 3 min',price:5000,dur:180,type:'doublefish'},
  {id:'mega_luck',     name:'Mega Luck Potion',icon:'🌟',desc:'Luck ×10 for 2 min',      price:8000, dur:120, type:'luckBoost',  mul:10},
  {id:'god_potion',    name:'God Potion',       icon:'💎',desc:'ALL buffs for 2 min',     price:20000,dur:120, type:'all'},
];

function usePotion(p){
  if(S.gold<p.price){toast('Not enough gold!');return;}
  S.gold-=p.price;
  const dur=p.dur*1000;
  const endsAt=Date.now()+dur;
  if(!S.potions)S.potions={luckBoost:{active:false,endsAt:0},xpBoost:{active:false,endsAt:0},speedBoost:{active:false,endsAt:0},doublefish:{active:false,endsAt:0}};
  if(p.type==='all'){
    Object.keys(S.potions).forEach(k=>{S.potions[k]={active:true,endsAt};});
    toast('💎 GOD MODE for '+p.dur+'s!');
  } else {
    S.potions[p.type]={active:true,endsAt};
    toast(p.icon+' '+p.name+' active for '+(p.dur/60).toFixed(1)+'min!');
  }
  // speed potion: restart auto with new interval
  if((p.type==='speedBoost'||p.type==='all')&&S.autoFishing){
    clearInterval(S.autoInterval);
    const spd=S.autoRodId==='autofish_god'?400:S.autoRodId==='autofish_ultra'?800:S.autoRodId==='autofish_elite'?1500:S.autoRodId==='autofish_fast'?3000:6000;
    S.autoInterval=setInterval(autoFishTick,Math.max(200,Math.round(spd/2)));
  }
  updateHUD();saveGame();
}

// Potion tick (check expiry)
setInterval(()=>{
  if(!S.potions)return;
  const now=Date.now();let changed=false;
  Object.keys(S.potions).forEach(k=>{
    if(S.potions[k].active&&now>S.potions[k].endsAt){
      S.potions[k].active=false;changed=true;
      toast('⏰ '+k+' potion expired!');
    }
  });
  if(changed)updateHUD();
},5000);

