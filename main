const EXP_TABLE=[];
for(let i=1;i<=100;i++) EXP_TABLE.push(Math.round(50*Math.pow(i,1.6)));
function getExpNeeded(lvl){return EXP_TABLE[Math.min(lvl-1,99)]||9999999;}

