function openTrade(){
  tradeTab='mutate';
  document.querySelectorAll('#trade-tabs .tbtn').forEach((t,i)=>{t.classList.toggle('active',i===0);});
  renderTradeContent('mutate');
  openOv('trade-ov');
}
function renderTradeContent(tab){
  tradeTab=tab;
  const c=document.getElementById('trade-content');c.innerHTML='';
  document.getElementById('trade-msg').textContent='';
  if(tab==='mutate') renderMutate(c);
  else if(tab==='appraise') renderAppraise(c);
  else renderConvert(c);
}

// MUTATE TAB
let selectedFishIdx=null;
let selectedMutService=null;
function renderMutate(container){
  selectedFishIdx=null;selectedMutService=null;
  if(!S.inventory.length){container.innerHTML='<div style="color:var(--td);font-style:italic;font-size:12px">No fish in your bag to mutate!</div>';return;}
  container.innerHTML=`
    <div style="display:flex;gap:14px;width:100%;max-width:720px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px">
        <div class="ptitle">Select Fish</div>
        <div id="mut-fish-list" style="max-height:40vh;overflow-y:auto;display:flex;flex-direction:column;gap:5px;"></div>
      </div>
      <div style="flex:1;min-width:200px">
        <div class="ptitle">Mutation Service</div>
        <div id="mut-svc-list" style="max-height:40vh;overflow-y:auto;display:flex;flex-direction:column;gap:5px;"></div>
      </div>
      <div style="flex:0 0 160px;min-width:140px">
        <div class="ptitle">Preview</div>
        <div id="mut-preview" style="background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.07);border-radius:3px;padding:10px;font-size:10px;color:var(--td);text-align:center;min-height:100px;display:flex;align-items:center;justify-content:center;">Select fish & service</div>
        <button class="trade-exec" id="mut-exec-btn" disabled style="width:100%;margin-top:8px;">Apply</button>
      </div>
    </div>`;
  const fishList=document.getElementById('mut-fish-list');
  S.inventory.forEach((c,i)=>{
    const div=document.createElement('div');div.className='inv-fish rarity-'+c.fish.rarity;div.style.cursor='pointer';div.style.marginBottom='2px';
    const lbl=(c.mut.id!=='normal'?c.mut.name+' ':'')+c.fish.name;
    div.innerHTML=`<div class="if-icon">${c.fish.icon}</div><div class="if-info"><div class="if-name">${lbl}</div><div class="if-sub">${c.size}cm · ${c.value.toLocaleString()}g</div></div>`;
    div.addEventListener('click',()=>{selectedFishIdx=i;document.querySelectorAll('#mut-fish-list .inv-fish').forEach(d=>d.style.borderColor='');div.style.borderColor='var(--gold)';updateMutPreview();});
    fishList.appendChild(div);
  });
  const svcList=document.getElementById('mut-svc-list');
  MUTATE_SERVICES.forEach(svc=>{
    const can=S.gold>=svc.cost;
    const div=document.createElement('div');div.className='trade-card';div.style.padding='8px 10px';
    div.innerHTML=`<div style="display:flex;align-items:center;gap:7px"><div style="font-size:18px">${svc.icon}</div><div><div style="font-family:'Cinzel',serif;font-size:9px">${svc.name}</div><div style="font-size:8px;color:var(--td)">${svc.desc}</div><div style="font-size:9px;color:${can?'var(--gold)':'var(--red)'}">Cost: ${svc.cost.toLocaleString()}g</div></div></div>`;
    div.addEventListener('click',()=>{selectedMutService=svc;document.querySelectorAll('#mut-svc-list .trade-card').forEach(d=>d.classList.remove('selected'));div.classList.add('selected');updateMutPreview();});
    svcList.appendChild(div);
  });
}
function updateMutPreview(){
  const prev=document.getElementById('mut-preview');
  const btn=document.getElementById('mut-exec-btn');
  if(selectedFishIdx===null||!selectedMutService){prev.textContent='Select fish & service';if(btn)btn.disabled=true;return;}
  const c=S.inventory[selectedFishIdx];
  const svc=selectedMutService;
  const newMut=MUTATIONS.find(m=>m.id===svc.targetMut)||{id:'normal',name:'',pMul:1,sMul:1,color:'#a0b0c0'};
  const newVal=Math.round(c.value/c.mut.pMul*newMut.pMul);
  prev.innerHTML=`<div><div style="font-size:24px">${c.fish.icon}</div><div style="font-size:10px;font-family:'Cinzel',serif;margin:4px 0">${newMut.name?newMut.name+' ':''}<br>${c.fish.name}</div><div style="font-size:9px;color:${newMut.color||'#a0b0c0'}">${newMut.name||'Normal'} mutation</div><div style="font-size:10px;color:var(--gold);margin-top:4px">${newVal.toLocaleString()}g</div></div>`;
  if(btn){btn.disabled=S.gold<svc.cost;btn.textContent='Apply ('+svc.cost.toLocaleString()+'g)';}
  if(btn)btn.onclick=()=>executeMutate();
}
function executeMutate(){
  if(selectedFishIdx===null||!selectedMutService)return;
  const svc=selectedMutService;
  if(S.gold<svc.cost){toast('Not enough gold!');return;}
  S.gold-=svc.cost;
  const c=S.inventory[selectedFishIdx];
  const newMut=MUTATIONS.find(m=>m.id===svc.targetMut)||{id:'normal',name:'',pMul:1,sMul:1,color:'#a0b0c0'};
  const oldVal=c.value;c.mut=newMut;
  c.value=Math.round(oldVal/oldVal*oldVal/c.mut.pMul*newMut.pMul)||Math.round(c.fish.price*newMut.pMul);
  updateHUD();renderInventory();saveGame();
  toast('✨ Mutation applied! '+c.fish.name+' is now '+(newMut.name||'Normal')+'!');
  renderTradeContent('mutate');
}

// APPRAISE TAB
