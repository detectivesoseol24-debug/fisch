const DB_KEY='fisch_v2_accounts';
function getAccts(){try{return JSON.parse(localStorage.getItem(DB_KEY)||'{}')}catch(e){return{}}}
function saveAccts(a){localStorage.setItem(DB_KEY,JSON.stringify(a));}

function saveGame(){
  if(!currentUser)return;
  const a=getAccts();
  a[currentUser].save={
    gold:S.gold,totalCatches:S.totalCatches,totalGoldEarned:S.totalGoldEarned,mutationsCaught:S.mutationsCaught,
    currentArea:S.currentArea,unlockedAreas:S.unlockedAreas,currentRod:S.currentRod,currentBait:S.currentBait,
    ownedRods:S.ownedRods,baitInventory:S.baitInventory,
    inventory:S.inventory.map(c=>({fishId:c.fish.id,mutId:c.mut.id,size:c.size,weight:c.weight,value:c.value,isAuto:c.isAuto})),
    caughtFishIds:[...S.caughtFishIds],quests:S.quests,rodsOwned:S.rodsOwned,
    areasVisited:[...S.areasVisited],bloodCatches:S.bloodCatches,auroraCatches:S.auroraCatches,
    deepTimes:S.deepTimes,rareCatches:S.rareCatches,exoticCatches:S.exoticCatches,legCount:S.legCount,
    thunderCatches:S.thunderCatches,blizzCatches:S.blizzCatches,mythicCatches:S.mythicCatches,
    prismaticCaught:S.prismaticCaught,goldenMutCaught:S.goldenMutCaught,darkMutCaught:S.darkMutCaught,
    eventsEncountered:[...S.eventsEncountered],eventCatches:S.eventCatches,
    items:S.items,shopTimer:S.shopTimer,shopPurchased:S.shopPurchased,
    autoRodId:S.autoRodId,fishLog:S.fishLog,
    level:S.level,exp:S.exp,title:S.title,ownedTitles:S.ownedTitles,
    potions:S.potions,shinyMutCaught:S.shinyMutCaught,areaCatches:S.areaCatches,
    prismaticCaught:S.prismaticCaught,goldenMutCaught:S.goldenMutCaught,
    darkMutCaught:S.darkMutCaught,mythicCatches:S.mythicCatches,
    savedAt:Date.now(),
  };
  saveAccts(a);
}

function loadGame(sv){
  if(!sv)return;
  Object.keys(sv).forEach(k=>{
    if(k==='caughtFishIds') S.caughtFishIds=new Set(sv.caughtFishIds||[]);
    else if(k==='areasVisited') S.areasVisited=new Set(sv.areasVisited||['starter']);
    else if(k==='eventsEncountered') S.eventsEncountered=new Set(sv.eventsEncountered||[]);
    else if(k==='quests'){
      const def=buildQuests();
      ['daily','weekly','main','rod','item'].forEach(tab=>{
        S.quests[tab]=(sv.quests[tab]||def[tab]).map(sq=>{const dq=def[tab].find(d=>d.id===sq.id);return dq?{...dq,...sq}:sq;});
        def[tab].forEach(dq=>{if(!S.quests[tab].find(sq=>sq.id===dq.id))S.quests[tab].push(dq);});
      });
    } else if(k==='shopTimer'){S.shopTimer=sv[k];}
    else if(k==='shopPurchased'){S.shopPurchased=sv[k]||{};}
    else if(k==='fishLog'){S.fishLog=sv[k]||{};}
    else if(k==='inventory'){
      S.inventory=(sv.inventory||[]).map(ci=>{
        const fish=FISH_DB.find(f=>f.id===ci.fishId),mut=MUTATIONS.find(m=>m.id===ci.mutId);
        return fish&&mut?{fish,mut,size:ci.size,weight:ci.weight,value:ci.value,isAuto:ci.isAuto||false}:null;
      }).filter(Boolean);
    } else if(k==='savedAt'){}
    else if(k in S) S[k]=sv[k];
  });
  const area=AREAS.find(a=>a.id===S.currentArea);
  if(area){document.getElementById('biome-name').textContent=area.name.toUpperCase();document.getElementById('biome-desc').textContent=area.desc;}
}
setInterval(saveGame,30000);

// ═══════════════════════════════════════════════
//  LOGIN SCREEN
// ═══════════════════════════════════════════════
function setupLogin(){
  const bg=document.getElementById('login-bg');
  for(let i=0;i<14;i++){
    const b=document.createElement('div');b.className='lbubble';
    const sz=6+Math.random()*18;
    b.style.cssText=`width:${sz}px;height:${sz}px;left:${Math.random()*100}%;animation-duration:${8+Math.random()*14}s;animation-delay:${-Math.random()*14}s;`;
    bg.appendChild(b);
  }
  updateAcctLabel();
  let loginMode=true;
  document.getElementById('tab-login').addEventListener('click',()=>{loginMode=true;document.getElementById('tab-login').classList.add('active');document.getElementById('tab-reg').classList.remove('active');document.getElementById('l-submit').textContent='Login';document.getElementById('l-err').textContent='';});
  document.getElementById('tab-reg').addEventListener('click',()=>{loginMode=false;document.getElementById('tab-reg').classList.add('active');document.getElementById('tab-login').classList.remove('active');document.getElementById('l-submit').textContent='Register';document.getElementById('l-err').textContent='';});
  function doSubmit(){
    const usn=document.getElementById('l-usn').value.trim();
    const pw=document.getElementById('l-pw').value;
    const err=document.getElementById('l-err');
    if(!usn){err.textContent='Enter a username';return;}
    if(!pw){err.textContent='Enter a password';return;}
    if(usn.length<3){err.textContent='Username must be 3+ chars';return;}
    if(pw.length<4){err.textContent='Password must be 4+ chars';return;}
    const a=getAccts();
    if(loginMode){
      if(!a[usn]){err.textContent='Account not found';return;}
      if(a[usn].pw!==btoa(pw)){err.textContent='Wrong password';return;}
      doLogin(usn,a[usn].save);
    } else {
      if(a[usn]){err.textContent='Username already taken';return;}
      if(!/^[a-zA-Z0-9_]+$/.test(usn)){err.textContent='Only letters/numbers/underscore';return;}
      a[usn]={pw:btoa(pw),save:null,createdAt:Date.now()};
      saveAccts(a);updateAcctLabel();
      doLogin(usn,null);
      setTimeout(()=>showTutorial(),500);
    }
  }
  document.getElementById('l-submit').addEventListener('click',doSubmit);
  document.getElementById('l-pw').addEventListener('keydown',e=>{if(e.key==='Enter')doSubmit();});
  document.getElementById('l-usn').addEventListener('keydown',e=>{if(e.key==='Enter')document.getElementById('l-pw').focus();});
}
function updateAcctLabel(){
  const a=getAccts(),c=Object.keys(a).length;
  document.getElementById('l-acct').textContent=c===0?'No accounts — be the first!':c+' account'+(c===1?'':'s')+' registered';
}
function doLogin(usn,sv){
  currentUser=usn;
  Object.assign(S,{
    gold:200,totalCatches:0,totalGoldEarned:0,mutationsCaught:0,
    currentArea:'starter',unlockedAreas:['starter'],currentRod:'starter',currentBait:'none',
    ownedRods:['starter'],baitInventory:{},inventory:[],caughtFishIds:new Set(),
    phase:'idle',event:null,eventTimer:0,quests:buildQuests(),shopTab:'rods',questTab:'daily',
    rodsOwned:0,areasVisited:new Set(['starter']),bloodCatches:0,auroraCatches:0,deepTimes:0,
    rareCatches:0,exoticCatches:0,legCount:0,thunderCatches:0,blizzCatches:0,mythicCatches:0,
    prismaticCaught:0,goldenMutCaught:0,darkMutCaught:0,
    eventsEncountered:new Set(),eventCatches:0,
    items:{bloodtotem:0,auroratotem:0,stormtotem:0,meteortotem:0},autoFishing:false,autoInterval:null,autoRodId:null,
    fishLog:{},shopTimer:Math.floor(Date.now()/900000),shopPurchased:{},
    level:1,exp:0,title:'Novice',ownedTitles:['Novice'],
    potions:{luckBoost:{active:false,endsAt:0},xpBoost:{active:false,endsAt:0},speedBoost:{active:false,endsAt:0},doublefish:{active:false,endsAt:0}},
    shinyMutCaught:0,areaCatches:{},prismaticCaught:0,goldenMutCaught:0,darkMutCaught:0,mythicCatches:0,
  });
  if(sv)loadGame(sv);
  document.getElementById('login-screen').classList.add('hidden');
  document.title='FISCH — '+usn;
  const isOwner=usn===OWNER;
  const obadge=isOwner?'<span class="owner-badge">OWNER</span>':'';
  document.getElementById('logo-el').innerHTML='F<span style="color:var(--gold)">I</span>SCH <span style="font-size:11px;color:var(--td);letter-spacing:2px">'+usn+'</span>'+obadge;
  const ahb=document.getElementById('admin-hdr-btn');
  if(ahb)ahb.style.display=isOwner?'':'none';
  init();
}
function doLogout(){
  saveGame();
  if(S.autoInterval){clearInterval(S.autoInterval);S.autoInterval=null;}
  currentUser=null;
  document.getElementById('l-usn').value='';document.getElementById('l-pw').value='';document.getElementById('l-err').textContent='';
  document.getElementById('login-screen').classList.remove('hidden');
  document.getElementById('logo-el').innerHTML='F<span style="color:var(--gold)">I</span>SCH';
  updateAcctLabel();
}

