// ═══════════════════════════════════════════════
//  AREA BACKGROUNDS
// ═══════════════════════════════════════════════
function updateAreaBg(areaId){
  const bg=document.getElementById('ocean-bg');
  bg.className='area-'+areaId;
  const ws=document.getElementById('water-scene');
  ws.className='area-'+areaId;
  const wse=document.getElementById('water-surface-el');
  wse.className='water-surface-el area-'+areaId;
  // update wave color per area
  const waveColors={starter:'rgba(10,171,189,.08)',coral:'rgba(34,180,100,.08)',deep:'rgba(20,20,100,.1)',volcano:'rgba(180,60,0,.1)',arctic:'rgba(150,200,255,.08)',abyss:'rgba(100,0,120,.08)',celest:'rgba(80,80,200,.08)',ruins:'rgba(120,100,30,.07)',divine:'rgba(200,200,200,.05)',shadow:'rgba(80,0,120,.07)',timevoid:'rgba(60,60,200,.08)',dream:'rgba(100,50,200,.08)',origin:'rgba(255,255,255,.04)',voidrealm:'rgba(100,0,150,.08)',stellar:'rgba(200,180,0,.06)',primordial:'rgba(200,60,0,.08)'};
  const wl=bg.querySelector('.wave-layer');
  if(wl)wl.style.background=`linear-gradient(90deg,transparent,${waveColors[areaId]||'rgba(10,171,189,.08)'},transparent)`;
}

function spawnBubbles(){
  const bg=document.getElementById('ocean-bg');
  bg.querySelectorAll('.bubble').forEach(b=>b.remove());
  for(let i=0;i<18;i++){
    const b=document.createElement('div');b.className='bubble';
    const sz=4+Math.random()*14;
    const colors={starter:'rgba(10,171,189,.25)',coral:'rgba(34,180,100,.25)',deep:'rgba(50,50,180,.2)',volcano:'rgba(200,80,10,.2)',arctic:'rgba(150,220,255,.2)',abyss:'rgba(120,0,150,.2)',celest:'rgba(100,100,255,.2)',ruins:'rgba(140,120,40,.18)',divine:'rgba(200,200,200,.15)'};
    const col=colors[S.currentArea]||'rgba(10,171,189,.25)';
    b.style.cssText=`width:${sz}px;height:${sz}px;left:${Math.random()*100}%;animation-duration:${7+Math.random()*12}s;animation-delay:${-Math.random()*12}s;background:radial-gradient(circle at 30% 30%,${col},transparent);border:1px solid ${col.replace('.25','.12').replace('.2','.1')};`;
    bg.appendChild(b);
  }
  // fish silhouettes in water scene
  const sc=document.getElementById('water-scene');
  sc.querySelectorAll('.fish-sil').forEach(f=>f.remove());
  ['🐟','🐠','🦑','🐡','🐙'].forEach((f,i)=>{
    const fs=document.createElement('div');fs.className='fish-sil';fs.textContent=f;
    fs.style.cssText=`top:${28+i*12}%;animation-duration:${7+i*3}s;animation-delay:${-i*2}s;`;
    sc.appendChild(fs);
  });
}

function updateHUD(){
  document.getElementById('hud-gold').textContent=S.gold.toLocaleString();
  document.getElementById('hud-catches').textContent=S.totalCatches;
  // Level/EXP
  const expN=getExpNeeded(S.level);
  const lvlEl=document.getElementById('hud-level');
  if(lvlEl)lvlEl.textContent='Lv.'+S.level+' ('+S.exp+'/'+expN+')';
  const expBar=document.getElementById('exp-bar-fill');
  if(expBar)expBar.style.width=Math.round(S.exp/expN*100)+'%';
  // Title
  const titleEl=document.getElementById('hud-title');
  const tt=TITLES.find(t=>t.id===S.title);
  if(titleEl)titleEl.textContent=S.title;
  if(titleEl&&tt)titleEl.style.color=tt.color||'#aaa';
  // Potion indicators
  // Potion indicators - buff bar
  const pots=S.potions||{};const now2=Date.now();
  const buffBar=document.getElementById('buff-bar');
  if(buffBar){
    buffBar.innerHTML='';
    const buffInfo={luckBoost:{icon:'🍀',label:'Luck ×3',col:'#44ff88'},xpBoost:{icon:'⚗️',label:'2× EXP',col:'#88ffcc'},speedBoost:{icon:'⚡',label:'Fast',col:'#ffee44'},doublefish:{icon:'🪄',label:'Double',col:'#ff88ff'}};
    Object.entries(pots).forEach(([k,v])=>{
      if(!v.active||now2>=v.endsAt)return;
      const rem=Math.round((v.endsAt-now2)/1000);
      const bi=buffInfo[k]||{icon:'?',label:k,col:'#aaa'};
      const pill=document.createElement('div');
      pill.className='buff-pill';
      pill.style.cssText=`background:${bi.col}18;border:1px solid ${bi.col}44;color:${bi.col}`;
      pill.textContent=`${bi.icon} ${bi.label} ${rem}s`;
      buffBar.appendChild(pill);
    });
  }
  const potEl=document.getElementById('hud-potions');if(potEl)potEl.textContent='';// handled by buff-bar
  const rod=RODS.find(r=>r.id===S.currentRod);
  document.getElementById('hud-rod').textContent=rod.icon+' '+rod.name;
  const ev=document.getElementById('hud-event');
  if(S.event){const e=EVENTS[S.event];ev.textContent=e.icon+' '+e.name;ev.style.color=e.color;}
  else{ev.textContent='—';ev.style.color='var(--td)';}
  renderRodStats();
}

// ═══════════════════════════════════════════════
//  WEATHER / EVENTS
// ═══════════════════════════════════════════════
function maybeEvent(){
  if(S.event||getGEV())return;
  const keys=Object.keys(EVENTS);
  if(Math.random()<0.18){const t=keys[Math.floor(Math.random()*keys.length)];startEvent(t,false);}
}
function _applyEventVisuals(type){
  const e=EVENTS[type];if(!e)return;
  const b=document.getElementById('event-banner');
  b.className='show '+type;b.textContent=e.banner;
  buildWeatherParticles(type);updateHUD();
}
function startEvent(type,broadcast=false){
  const e=EVENTS[type];if(!e)return;
  S.event=type;S.eventTimer=e.dur;
  _applyEventVisuals(type);
  showEvNotif(type);
  playEvSound(type);
  toast(e.icon+' '+e.name+' started!');
  if(broadcast)setGEV(type,e.dur);
}
function _endEventLocal(){
  const old=S.event;S.event=null;
  document.getElementById('event-banner').className='';
  document.getElementById('event-banner').textContent='';
  document.getElementById('weather-overlay').innerHTML='';
  document.getElementById('weather-overlay').className='';
  if(old)toast('The '+EVENTS[old].name+' has ended...');
  updateHUD();
}
function endEvent(){_endEventLocal();}
function tickEvent(){
  if(!S.event)return;
  S.eventTimer--;
  if(S.eventTimer<=0){
    const ge=getGEV();
    if(ge&&ge.type===S.event&&Date.now()<ge.endsAt)return;// still running globally
    endEvent();
  }
}

// ── EVENT NOTIFICATION ──
let _notifTm;
function showEvNotif(type){
  const e=EVENTS[type];if(!e)return;
  const el=document.getElementById('ev-notif');if(!el)return;
  el.style.background=`linear-gradient(135deg,${e.color}18,rgba(3,14,30,.96))`;
  el.style.borderColor=e.color+'55';
  document.getElementById('evn-title').style.color=e.color;
  document.getElementById('evn-title').textContent=e.icon+' '+e.name.toUpperCase();
  document.getElementById('evn-sub').textContent=e.banner.replace(/^\S+\s/,'');
  document.getElementById('evn-time').textContent='Lasts '+e.dur+'s';
  el.classList.add('on');
  clearTimeout(_notifTm);
  _notifTm=setTimeout(()=>el.classList.remove('on'),5500);
}

// ── AUDIO FEEDBACK ──
function playEvSound(type){
  try{
    const ctx=new(window.AudioContext||window.webkitAudioContext)();
    const osc=ctx.createOscillator(),g=ctx.createGain();
    osc.connect(g);g.connect(ctx.destination);
    const freqs={aurora:440,bloodmoon:110,thunder:220,storm:180,rain:330,fog:260,blizzard:380,meteor:550,mutation_hunt:660,shiny_tide:880,sparkling_storm:770,megalodon_hunt:80,leviathan_hunt:90,ancient_tide:350,phantom_mist:300,glowing_depths:440};
    osc.frequency.value=freqs[type]||440;
    osc.type=(type==='bloodmoon'||type==='megalodon_hunt'||type==='leviathan_hunt')?'sawtooth':'sine';
    g.gain.setValueAtTime(.28,ctx.currentTime);
    g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+1.2);
    osc.start();osc.stop(ctx.currentTime+1.2);
  }catch(e){}
}
function activateTotem(type){
  const map={bloodtotem:'bloodmoon',auroratotem:'aurora',stormtotem:'storm',meteortotem:'meteor'};
  const ev=map[type];if(!ev){toast('Unknown totem');return;}
  if((S.items[type]||0)<1){toast('No '+type+' left!');return;}
  S.items[type]--;
  if(S.event)endEvent();
  startEvent(ev);renderItems();
}

function buildWeatherParticles(type){
  const ov=document.getElementById('weather-overlay');
  ov.innerHTML='';ov.className=type;
  if(type==='rain'||type==='storm'){
    for(let i=0;i<60;i++){
      const d=document.createElement('div');d.className='rain-drop';
      const h=30+Math.random()*80;
      d.style.cssText=`left:${Math.random()*100}%;top:${-h}px;height:${h}px;animation-duration:${.4+Math.random()*.4}s;animation-delay:${-Math.random()*2}s;opacity:${type==='storm'?.8:.5}`;
      ov.appendChild(d);
    }
    if(type==='storm')ov.style.background='rgba(20,10,40,.15)';
  } else if(type==='thunder'){
    for(let i=0;i<40;i++){
      const d=document.createElement('div');d.className='rain-drop';
      d.style.cssText=`left:${Math.random()*100}%;top:0;height:${40+Math.random()*60}px;animation-duration:${.3+Math.random()*.3}s;animation-delay:${-Math.random()*1}s;opacity:.7;background:linear-gradient(rgba(220,220,100,.7),transparent)`;
      ov.appendChild(d);
    }
    setInterval(()=>{
      if(S.event!=='thunder')return;
      const l=document.createElement('div');l.className='lightning';
      l.style.cssText=`left:${Math.random()*100}%;top:0;height:${80+Math.random()*120}px;`;
      ov.appendChild(l);setTimeout(()=>l.remove(),200);
    },800);
    ov.style.background='rgba(30,20,60,.1)';
  } else if(type==='blizzard'){
    for(let i=0;i<80;i++){
      const s=document.createElement('div');s.className='snow-flake';
      const sz=2+Math.random()*5;
      s.style.cssText=`width:${sz}px;height:${sz}px;left:${Math.random()*100}%;top:${-sz}px;animation-duration:${2+Math.random()*4}s;animation-delay:${-Math.random()*4}s;opacity:${.4+Math.random()*.4}`;
      ov.appendChild(s);
    }
    ov.style.background='rgba(180,220,255,.05)';
  } else if(type==='fog'){
    for(let i=0;i<3;i++){
      const f=document.createElement('div');f.className='fog-layer';
      f.style.cssText=`top:${i*30}%;opacity:.${2+i};animation-delay:${-i*4}s;`;
      ov.appendChild(f);
    }
  } else if(type==='aurora'){
    ov.style.background='linear-gradient(180deg,rgba(136,255,204,.08) 0%,rgba(68,204,255,.05) 40%,transparent 70%)';
    ov.style.animation='auroraShimmer 4s ease-in-out infinite alternate';
  } else if(type==='bloodmoon'){
    ov.style.background='radial-gradient(ellipse at 50% 0%,rgba(200,20,20,.12) 0%,transparent 70%)';
  } else if(type==='meteor'){
    ov.style.background='rgba(30,15,5,.05)';
    for(let i=0;i<15;i++){
      const m=document.createElement('div');
      m.style.cssText=`position:absolute;width:2px;height:${20+Math.random()*40}px;left:${Math.random()*100}%;top:0;background:linear-gradient(rgba(255,160,60,.8),transparent);animation:rainFall ${.5+Math.random()*.5}s linear infinite;animation-delay:${-Math.random()*3}s;transform:rotate(${15+Math.random()*20}deg)`;
      ov.appendChild(m);
    }
  }
}

// ═══════════════════════════════════════════════
//  AREAS
// ═══════════════════════════════════════════════
function renderAreas(){
  const list=document.getElementById('area-list');list.innerHTML='';
  AREAS.forEach(a=>{
    const unlocked=S.unlockedAreas.includes(a.id),active=S.currentArea===a.id;
    const div=document.createElement('div');
    div.className=`area-card ${active?'active':''} ${!unlocked?'area-locked':''}`;
    div.innerHTML=`<div class="area-name">${a.emoji} ${a.name}</div><div class="area-sub">${unlocked?a.desc:'🔒 '+a.cost.toLocaleString()+'g'}</div>`;
    div.addEventListener('click',()=>unlocked?selectArea(a.id):tryUnlock(a));
    list.appendChild(div);
  });
}
function selectArea(id){
  S.currentArea=id;S.areasVisited.add(id);
  const a=AREAS.find(x=>x.id===id);
  document.getElementById('biome-name').textContent=a.name.toUpperCase();
  document.getElementById('biome-desc').textContent=a.desc;
  updateAreaBg(id);spawnBubbles();
  renderAreas();setStatus('You arrive at '+a.name+'. Cast your line!');
  if(id==='deep')S.deepTimes++;
  tickQ();
}
function tryUnlock(a){
  if(S.gold>=a.cost){
    S.gold-=a.cost;S.unlockedAreas.push(a.id);
    updateHUD();renderAreas();toast('🌊 '+a.name+' UNLOCKED!');selectArea(a.id);
    S.quests.main.filter(q=>q.type==='area'&&q.target===a.id&&!q.claimed).forEach(q=>q.progress=1);
    checkBadges();saveGame();
  }else toast('Need '+a.cost.toLocaleString()+'g to unlock');
}

// ═══════════════════════════════════════════════
//  FISHING
// ═══════════════════════════════════════════════
function castRod(){
  if(S.phase!=='idle')return;
  S.phase='casting';
  document.getElementById('cast-btn').disabled=true;
  document.getElementById('cast-hint').style.display='none';
  const line=document.getElementById('fishing-line'),bobb=document.getElementById('bobber');
  line.style.display='block';
  let h=0;const bx=43+Math.random()*14;
  line.style.left=bx+'%';bobb.style.left=bx+'%';
  const ext=setInterval(()=>{
    h+=5;line.style.height=h+'px';bobb.style.top=h+'px';bobb.style.display='block';
    if(h>=140){clearInterval(ext);S.phase='waiting';setStatus('Waiting for a bite...');scheduleNibble();}
  },16);
}
function scheduleNibble(){
  setTimeout(()=>{
    if(S.phase!=='waiting')return;
    document.getElementById('bobber').classList.add('biting');
    setStatus('Something is biting! Reel it in!');
    setTimeout(()=>startMG(),300);
  },1000+Math.random()*2500);
}

function pickFish(){
  let pool=FISH_DB.filter(f=>f.area===S.currentArea);
  if(!pool.length)pool=FISH_DB.slice(0,5);
  const rod=RODS.find(r=>r.id===S.currentRod)||RODS[0];
  const bait=BAITS.find(b=>b.id===S.currentBait)||BAITS[0];
  let luck=rod.luck+(bait?bait.luck:0);
  const ev=S.event?EVENTS[S.event]:null;
  if(ev)luck*=ev.luckMul;
  if(S.event==='aurora'&&S.currentRod==='aurorarod')luck+=5;
  let mythicMul=ev?ev.mythicMul:1;
  if(S.event==='blizzard'&&S.currentArea==='arctic')luck*=3;
  const secretBonus=S.event==='fog'?0.2:0;
  // Hunt events: inject target fish into pool at high weight
  if(ev&&ev.targetFish){
    const tf=FISH_DB.find(f=>f.id===ev.targetFish);
    if(tf){const mult=S.currentRod==='huntrod'?20:8;for(let i=0;i<mult;i++)pool.push(tf);}
  }
  const w={
    common:    Math.max(3,55-luck*1.5),
    uncommon:  20+luck*(S.event==='rain'?2:1),
    rare:      8+luck*0.8*(S.event==='storm'?2:1),
    legendary: 3+luck*0.4,
    mythic:    (0.8+luck*0.12)*mythicMul,
    exotic:    (0.4+luck*0.04)*(S.currentRod==='neptune'||S.currentRod==='cosmic'?2:1),
    secret:    (0.04+luck*0.002+secretBonus),
    divine:    (0.008+luck*0.0004),
  };
  let weighted=[];
  pool.forEach(f=>{const n=Math.max(1,Math.round(w[f.rarity]||1));for(let i=0;i<n;i++)weighted.push(f);});
  if(!weighted.length)weighted=pool;
  return weighted[Math.floor(Math.random()*weighted.length)];
}

// ═══════════════════════════════════════════════
//  MINIGAME — MUCH EASIER
// ═══════════════════════════════════════════════
function startMG(){
  S.phase='minigame';
  const fish=pickFish();MG.fish=fish;
  MG.active=true;MG.prog=0;MG.lastTs=null;MG.indVel=0;MG.indPos=50;
  const rod=RODS.find(r=>r.id===S.currentRod);
  const bait=BAITS.find(b=>b.id===S.currentBait);
  let ctrl=rod.ctrl+(bait?bait.ctrl:0);
  // Rod skill bonuses
  if(S.currentRod==='cosmic')ctrl+=5;
  if(S.currentRod==='crystalrod')ctrl+=3;
  // wider zone = easier
  MG.zoneWidth=Math.max(25,50-fish.diff*1.8+ctrl*1.8);
  // crystal rod extra width
  if(S.currentRod==='crystalrod')MG.zoneWidth=Math.min(90,MG.zoneWidth+20);
  MG.zonePos=50-MG.zoneWidth/2;
  MG.diff=Math.max(1,fish.diff);
  // obsidian: faster zone
  MG.zoneVel=(Math.random()>.5?1:-1)*(0.08+fish.diff*(S.currentRod==='obsidian'?.09:.05));
  document.getElementById('mg-icon').textContent=fish.icon;
  const dl=['','Very Easy','Easy','Normal','Normal','Moderate','Hard','Hard','Brutal','Extreme','LEGENDARY'];
  document.getElementById('mg-diff').textContent=fish.name+' — '+(dl[Math.min(fish.diff,10)]);
  document.getElementById('mg-overlay').classList.add('active');
  updateMgUI();MG.raf=requestAnimationFrame(mgLoop);
}

function mgLoop(ts){
  if(!MG.active)return;
  const dt=MG.lastTs?Math.min((ts-MG.lastTs)/16,3):1;MG.lastTs=ts;
  const rod=RODS.find(r=>r.id===S.currentRod);
  const bait=BAITS.find(b=>b.id===S.currentBait);
  let ctrl=rod.ctrl+(bait?bait.ctrl:0);
  if(S.currentRod==='cosmic')ctrl+=5;
  if(S.currentRod==='crystalrod')ctrl+=3;
  // zone drift — slower = easier
  MG.zoneVel+=(Math.random()-.5)*0.1*MG.diff*dt;
  MG.zoneVel=Math.max(-1.2,Math.min(1.2,MG.zoneVel));
  MG.zonePos+=MG.zoneVel*dt;
  if(MG.zonePos<0){MG.zonePos=0;MG.zoneVel*=-1;}
  if(MG.zonePos+MG.zoneWidth>100){MG.zonePos=100-MG.zoneWidth;MG.zoneVel*=-1;}
  // indicator — easier: lower fish force, higher hold force
  const hold=MG.holding?-(2.5+ctrl*0.5):0;
  const fishF=0.55*MG.diff*dt;
  MG.indVel+=(fishF+hold)*dt*0.09;
  MG.indVel*=0.86;
  MG.indPos+=MG.indVel;MG.indPos=Math.max(2,Math.min(98,MG.indPos));
  const inZ=MG.indPos>=MG.zonePos&&MG.indPos<=(MG.zonePos+MG.zoneWidth);
  // progress gain faster, loss slower
  let gain=inZ?(1.6+rod.spd*0.2)*dt:-(0.45+MG.diff*0.08)*dt;
  // bamboo skill: -20% loss
  if(!inZ&&S.currentRod==='bamboo')gain*=0.8;
  // silver skill: +25% gain
  if(inZ&&S.currentRod==='silver')gain*=1.25;
  MG.prog+=gain;MG.prog=Math.max(0,Math.min(100,MG.prog));
  // iron rod: cannot fail if prog > 20
  if(S.currentRod==='iron'&&MG.prog>20)MG.prog=Math.max(20,MG.prog);
  updateMgUI();
  if(MG.prog>=100){endMG(true);return;}
  if(MG.prog<=0&&MG.indPos>=96){endMG(false);return;}
  MG.raf=requestAnimationFrame(mgLoop);
}
function updateMgUI(){
  document.getElementById('cp-bar').style.width=MG.prog+'%';
  document.getElementById('tz-ind').style.left=MG.indPos+'%';
  document.getElementById('tz-zone').style.left=MG.zonePos+'%';
  document.getElementById('tz-zone').style.width=MG.zoneWidth+'%';
}
function endMG(ok){
  MG.active=false;MG.lastTs=null;cancelAnimationFrame(MG.raf);
  document.getElementById('mg-overlay').classList.remove('active');
  document.getElementById('bobber').classList.remove('biting');
  resetLine();
  if(S.currentBait!=='none'){
    S.baitInventory[S.currentBait]=(S.baitInventory[S.currentBait]||0)-1;
    if(S.baitInventory[S.currentBait]<=0){delete S.baitInventory[S.currentBait];S.currentBait='none';toast('Bait ran out!');}
    renderRodStats();
  }
  if(ok)showReveal(MG.fish);
  else{S.phase='idle';document.getElementById('fail').classList.add('active');}
}
function resetLine(){document.getElementById('fishing-line').style.display='none';document.getElementById('bobber').style.display='none';}

// ═══════════════════════════════════════════════
//  MUTATION LOGIC
// ═══════════════════════════════════════════════
function rollMutation(fish){
  // Build mutation pool based on current event and rod skill
  let pool=[...MUTATIONS];
  const ev=S.event;
  const rod=S.currentRod;
  // Filter exclusive mutations: only include event-exclusive ones if event matches
  pool=pool.filter(m=>{
    if(!m.exclusive)return true;
    if(m.exclusive==='cosmic')return rod==='cosmic'; // ascend only for cosmic rod
    return m.exclusive===ev; // weather mutations only during their event
  });
  // Golden rod: boost mutation chance
  if(rod==='golden')pool=pool.map(m=>m.id!=='normal'?{...m,chance:m.chance*1.15}:m);
  // Titan rod: boost big/giant
  if(rod==='titanrod')pool=pool.map(m=>(m.id==='big'||m.id==='giant')?{...m,chance:m.chance*1.3}:m);
  // Cosmic rod: 10% chance ascend (force it)
  if(rod==='cosmic'&&Math.random()<0.10){return MUTATIONS.find(m=>m.id==='ascend');}
  // divine rod: 10% any becomes divine quality
  if(rod==='divinerod'&&Math.random()<0.10){return {id:'divine_wild',name:'Divine',pMul:25,sMul:2,color:'#ffffff'};}
  // roll
  let total=pool.reduce((s,m)=>s+m.chance,0);
  let r=Math.random()*total;
  for(const m of pool){if(r<m.chance)return m;r-=m.chance;}
  return MUTATIONS[0];
}

// ═══════════════════════════════════════════════
//  CATCH REVEAL
// ═══════════════════════════════════════════════
function showReveal(fish){
  S.phase='reveal';
  const mut=rollMutation(fish);
  const sBase=fish.min+Math.random()*(fish.max-fish.min);
  const size=Math.round(sBase*mut.sMul);
  const weight=+(size*0.03*(1+Math.random()*.5)).toFixed(2);
  const sMul=1+(size-fish.min)/Math.max(1,fish.max-fish.min)*.8;
  const value=Math.round(fish.price*sMul*mut.pMul);
  const cd={fish,mut,size,weight,value};

  document.getElementById('rv-icon').textContent=fish.icon;
  document.getElementById('rv-name').textContent=(mut.name?mut.name+' ':'')+fish.name;
  const re=document.getElementById('rv-rarity');
  re.textContent=fish.rarity[0].toUpperCase()+fish.rarity.slice(1);
  re.className='rv-rarity r-'+fish.rarity;
  document.getElementById('rv-size').textContent=size+'cm';
  document.getElementById('rv-weight').textContent=weight+'kg';
  document.getElementById('rv-val').textContent='+'+value.toLocaleString()+' Gold';
  const me=document.getElementById('rv-mut');
  if(mut.id!=='normal'){
    me.textContent='✨ '+mut.name.toUpperCase()+' MUTATION';
    me.style.display='block';me.style.color=mut.color||'var(--legendary)';
  } else me.style.display='none';

  document.getElementById('reveal').classList.add('active');
  document.getElementById('rv-btn').onclick=()=>{
    document.getElementById('reveal').classList.remove('active');
    S.inventory.push({...cd,isAuto:false});S.totalCatches++;
    S.caughtFishIds.add(fish.id);
    // fish log
    const logKey=fish.id;
    if(!S.fishLog[logKey]) S.fishLog[logKey]={biggestSize:0,firstCaught:Date.now(),count:0,biggestValue:0};
    S.fishLog[logKey].count++;
    if(size>S.fishLog[logKey].biggestSize){S.fishLog[logKey].biggestSize=size;S.fishLog[logKey].biggestWeight=weight;}
    if(value>S.fishLog[logKey].biggestValue)S.fishLog[logKey].biggestValue=value;
    if(mut.id!=='normal')S.mutationsCaught++;
    if(mut.id==='prismatic')S.prismaticCaught=(S.prismaticCaught||0)+1;
    if(mut.id==='golden')S.goldenMutCaught=(S.goldenMutCaught||0)+1;
    if(mut.id==='dark')S.darkMutCaught=(S.darkMutCaught||0)+1;
    if(mut.id==='shiny'||mut.id==='sparkling')S.shinyMutCaught=(S.shinyMutCaught||0)+1;
    if(fish.rarity==='mythic')S.mythicCatches=(S.mythicCatches||0)+1;
    if(!S.areaCatches)S.areaCatches={};
    S.areaCatches[S.currentArea]=(S.areaCatches[S.currentArea]||0)+1;
    if(mut.id==='prismatic')S.prismaticCaught++;
    if(mut.id==='golden')S.goldenMutCaught++;
    if(mut.id==='dark')S.darkMutCaught++;
    if(S.event==='bloodmoon')S.bloodCatches++;
    if(S.event==='aurora')S.auroraCatches++;
    if(S.event==='thunder')S.thunderCatches++;
    if(S.event==='blizzard')S.blizzCatches++;
    if(fish.rarity==='mythic')S.mythicCatches++;
    if(S.event){S.eventsEncountered.add(S.event);S.eventCatches++;}
    const hi=['rare','legendary','mythic','exotic','secret','divine'];
    if(hi.includes(fish.rarity))S.rareCatches++;
    if(['exotic','secret','divine'].includes(fish.rarity))S.exoticCatches++;
    if(fish.rarity==='legendary')S.legCount++;
    // rarity quests
    S.quests.main.filter(q=>q.type==='rarity'&&q.target===fish.rarity&&!q.claimed).forEach(q=>q.progress=1);
    S.quests.rod.filter(q=>q.type==='rarity'&&q.target===fish.rarity&&!q.claimed).forEach(q=>q.progress=1);
    S.quests.rod.filter(q=>q.type==='legcount'&&!q.claimed).forEach(q=>q.progress=S.legCount);
    renderInventory();updateHUD();tickQ();checkBadges();saveGame();
    toast('Caught '+(mut.name?mut.name+' ':'')+fish.name+'! Worth '+value.toLocaleString()+'g');
    resetIdle();
  };
}

// ═══════════════════════════════════════════════
//  AUTO FISHING
// ═══════════════════════════════════════════════
function toggleAuto(){
  if(!S.autoRodId){toast('Buy an Auto Fisher from Shop → Auto Fish!');return;}
  S.autoFishing=!S.autoFishing;
  const btn=document.getElementById('auto-btn'),info=document.getElementById('auto-info');
  if(S.autoFishing){
    btn.classList.add('auto-on');btn.textContent='🤖 AUTO ON';
    info.style.display='block';
    const spd=S.autoRodId==='autofish_god'?400:S.autoRodId==='autofish_ultra'?800:S.autoRodId==='autofish_elite'?1500:S.autoRodId==='autofish_fast'?3000:6000;
    const realSpd=(S.potions?.speedBoost?.active&&Date.now()<S.potions.speedBoost.endsAt)?Math.max(200,Math.round(spd/2)):spd;
    S.autoInterval=setInterval(autoFishTick,realSpd);
  } else {
    btn.classList.remove('auto-on');btn.textContent='🤖 Auto';
    info.style.display='none';
    clearInterval(S.autoInterval);S.autoInterval=null;
  }
}
function autoFishTick(){
  if(!S.autoFishing||S.phase!=='idle')return;
  const fish=pickFish();
  const mut=rollMutation(fish);
  const sBase=fish.min+Math.random()*(fish.max-fish.min);
  const size=Math.round(sBase*mut.sMul);
  const weight=+(size*0.03*(1+Math.random()*.5)).toFixed(2);
  const sMul=1+(size-fish.min)/Math.max(1,fish.max-fish.min)*.8;
  const value=Math.round(fish.price*sMul*mut.pMul);
  const cd={fish,mut,size,weight,value};
  S.inventory.push({...cd,isAuto:true});S.totalCatches++;S.caughtFishIds.add(fish.id);
  if(mut.id!=='normal')S.mutationsCaught++;
  if(mut.id==='prismatic')S.prismaticCaught++;
  if(mut.id==='golden')S.goldenMutCaught++;
  if(mut.id==='dark')S.darkMutCaught++;
  if(S.event==='bloodmoon')S.bloodCatches++;
  if(S.event==='aurora')S.auroraCatches++;
  if(S.event){S.eventsEncountered.add(S.event);S.eventCatches++;}
  const hi=['rare','legendary','mythic','exotic','secret','divine'];
  if(hi.includes(fish.rarity))S.rareCatches++;
  if(fish.rarity==='legendary')S.legCount++;
  if(fish.rarity==='mythic')S.mythicCatches++;
  // fish log
  if(!S.fishLog[fish.id])S.fishLog[fish.id]={biggestSize:0,firstCaught:Date.now(),count:0,biggestValue:0};
  S.fishLog[fish.id].count++;
  if(cd.size>S.fishLog[fish.id].biggestSize){S.fishLog[fish.id].biggestSize=cd.size;S.fishLog[fish.id].biggestWeight=cd.weight;}
  if(cd.value>S.fishLog[fish.id].biggestValue)S.fishLog[fish.id].biggestValue=cd.value;
  S.quests.main.filter(q=>q.type==='rarity'&&q.target===fish.rarity&&!q.claimed).forEach(q=>q.progress=1);
  // EXP
  const aexp=getExpForFish(fish,mut);addExp(aexp);
  // Double fish potion
  if(S.potions?.doublefish?.active&&Date.now()<S.potions.doublefish.endsAt){
    S.inventory.push({...cd,isAuto:true});S.totalCatches++;
  }
  // Check titles
  checkTitleUnlocks();
  renderInventory();updateHUD();tickQ();checkBadges();
  toast('🤖 Auto: '+(mut.name?'['+mut.name+'] ':'')+fish.name+' +'+aexp+'exp');
}

// ═══════════════════════════════════════════════
//  INVENTORY / SELL
// ═══════════════════════════════════════════════
const RCOLS={common:'#a0b0c0',uncommon:'#44cc88',rare:'#4488ff',legendary:'#cc44ff',mythic:'#ff8844',exotic:'#ff44aa',secret:'#ffe066',divine:'#ffffff'};
function renderInventory(){
  const list=document.getElementById('inv-list');
  if(!S.inventory.length){list.innerHTML='<div style="font-size:9px;color:var(--td);font-style:italic;padding:4px 0">No fish yet</div>';return;}
  list.innerHTML='';
  S.inventory.forEach((c,i)=>{
    const div=document.createElement('div');
    div.className='inv-fish rarity-'+c.fish.rarity;
    const lbl=(c.mut.id!=='normal'?c.mut.name+' ':'')+c.fish.name;
    const badge=c.isAuto
      ?'<span class="auto-badge auto">AUTO</span>'
      :'<span class="auto-badge manual">CAST</span>';
    div.innerHTML=`${badge}<div class="if-icon">${c.fish.icon}</div><div class="if-info"><div class="if-name">${lbl}</div><div class="if-sub">${c.size}cm·${c.weight}kg</div></div><div class="if-val">${c.value.toLocaleString()}g</div>`;
    div.addEventListener('click',()=>sellOne(i));
    // hover to show popup
    div.addEventListener('mouseenter',e=>showFishDetailPopup(c.fish,e));
    div.addEventListener('mouseleave',()=>hideFishDetailPopup());
    div.addEventListener('mousemove',e=>moveFishDetailPopup(e));
    list.appendChild(div);
  });
}
function sellOne(i){
  const c=S.inventory[i];S.gold+=c.value;S.totalGoldEarned+=c.value;
  S.inventory.splice(i,1);updateHUD();renderInventory();tickQ();checkBadges();saveGame();
  toast('Sold '+c.fish.name+' for '+c.value.toLocaleString()+'g!');
}
function sellAll(){
  if(!S.inventory.length){toast('Nothing to sell!');return;}
  let tot=0;S.inventory.forEach(c=>{tot+=c.value;S.totalGoldEarned+=c.value;});
  S.gold+=tot;S.inventory=[];updateHUD();renderInventory();tickQ();checkBadges();saveGame();
  toast('💰 Sold all for '+tot.toLocaleString()+'g!');
}

// ═══════════════════════════════════════════════
//  ROD STATS
// ═══════════════════════════════════════════════
function renderRodStats(){
  const rod=RODS.find(r=>r.id===S.currentRod);
  const bait=BAITS.find(b=>b.id===S.currentBait);
  const ev=S.event?EVENTS[S.event]:null;
  let luckBase=rod.luck+(bait?bait.luck:0);
  let luckDisplay=ev?'×'+ev.luckMul+' ('+Math.round(luckBase*ev.luckMul)+')':luckBase;
  const stats=[{l:'Luck',v:luckBase,display:luckDisplay,max:25},{l:'Control',v:rod.ctrl+(bait?bait.ctrl:0),max:20},{l:'Strength',v:rod.str,max:18},{l:'Speed',v:rod.spd,max:15}];
  const skill=ROD_SKILLS[S.currentRod];
  const el=document.getElementById('rod-stats');
  el.innerHTML=stats.map(s=>`<div class="srow"><span class="sl">${s.l}</span><div style="display:flex;align-items:center;gap:5px"><div class="sbar-w"><div class="sbar" style="width:${Math.min(100,s.v/s.max*100)}%"></div></div><span class="sv">${s.display||s.v}</span></div></div>`).join('');
  if(skill)el.innerHTML+=`<div style="margin-top:6px"><div style="font-size:8px;color:var(--td);letter-spacing:2px;margin-bottom:3px">ROD SKILL</div><span class="si-skill" style="background:${skill.color}22;color:${skill.color};border:1px solid ${skill.color}44">${skill.name}</span><div style="font-size:9px;color:var(--td);margin-top:3px">${skill.desc}</div></div>`;
  const bq=S.currentBait!=='none'?(S.baitInventory[S.currentBait]||0):0;
  el.innerHTML+=`<div class="srow" style="margin-top:4px"><span class="sl">Bait</span><span class="sv">${bait&&bait.id!=='none'?bait.icon+' '+bait.name+(bq?' ('+bq+')':''):'—'}</span></div>`;
}

// ═══════════════════════════════════════════════
//  SHOP
// ═══════════════════════════════════════════════
function renderShop(){
  const grid=document.getElementById('shop-grid');grid.innerHTML='';
  document.getElementById('shop-msg').textContent='';
  if(S.shopTab==='rods'){
    RODS.filter(r=>!r.quest&&r.id!=='starter').forEach(r=>{
      const owned=S.ownedRods.includes(r.id),eq=S.currentRod===r.id,ca=S.gold>=r.price;
      const skill=ROD_SKILLS[r.id];
      const div=document.createElement('div');div.className=`si ${eq?'equipped':owned?'owned':''}`;
      div.innerHTML=`<div class="si-icon">${r.icon}</div><div class="si-name">${r.name}</div><div class="si-desc">L${r.luck} C${r.ctrl} S${r.str} Spd${r.spd}</div>${skill?`<span class="si-skill" style="background:${skill.color}22;color:${skill.color};border:1px solid ${skill.color}44">${skill.name}</span>`:''}<div class="si-price ${!ca&&!owned?'cant':''}">${eq?'✓ Equipped':owned?'Equip':r.price.toLocaleString()+'g'}</div>`;
      div.addEventListener('click',()=>clickRod(r));grid.appendChild(div);
    });
    RODS.filter(r=>r.quest).forEach(r=>{
      const owned=S.ownedRods.includes(r.id),eq=S.currentRod===r.id;
      const skill=ROD_SKILLS[r.id];
      const div=document.createElement('div');div.className=`si ${eq?'equipped':owned?'owned':''}`;
      div.innerHTML=`<div class="si-icon">${r.icon}</div><div class="si-name">${r.name}</div><div class="si-desc">L${r.luck} C${r.ctrl} S${r.str} Spd${r.spd}</div>${skill?`<span class="si-skill" style="background:${skill.color}22;color:${skill.color};border:1px solid ${skill.color}44">${skill.name}</span>`:''}
        <div class="si-price" style="color:var(--teal)">${owned?(eq?'✓ Equipped':'Equip'):'🔒 Quest Reward'}</div>`;
      if(owned)div.addEventListener('click',()=>{S.currentRod=r.id;updateHUD();renderShop();toast(r.icon+' Equipped '+r.name+'!');});
      grid.appendChild(div);
    });
  } else if(S.shopTab==='baits'){
    BAITS.filter(b=>b.id!=='none').forEach(b=>{
      const qty=S.baitInventory[b.id]||0,eq=S.currentBait===b.id,ca=S.gold>=b.price;
      const div=document.createElement('div');div.className=`si ${eq?'equipped':''}`;
      div.innerHTML=`<div class="si-icon">${b.icon}</div><div class="si-name">${b.name}</div><div class="si-desc">Luck +${b.luck} · Ctrl +${b.ctrl}${qty?' · x'+qty:''} (${b.qty}/buy)</div><div class="si-price ${!ca?'cant':''}">${b.price.toLocaleString()}g</div>`;
      div.addEventListener('click',()=>clickBait(b));grid.appendChild(div);
    });
  } else if(S.shopTab==='auto'){
    const items=[
      {id:'autofish_basic',  name:'Basic Auto Fisher',   icon:'🤖', desc:'Auto-fish every 6s',          price:5000},
      {id:'autofish_fast',   name:'Fast Auto Fisher',    icon:'⚡', desc:'Auto-fish every 3s',           price:20000},
      {id:'autofish_elite',  name:'Elite Auto Fisher',   icon:'🌟', desc:'Auto-fish every 1.5s',         price:80000},
      {id:'autofish_ultra',  name:'Ultra Auto Fisher',   icon:'💫', desc:'Auto-fish every 0.8s',         price:250000},
      {id:'autofish_god',    name:'God Auto Fisher',     icon:'👑', desc:'Auto-fish every 0.4s (MAX)',   price:1000000},
    ];
    items.forEach(item=>{
      const owned=S.autoRodId===item.id,ca=S.gold>=item.price;
      const div=document.createElement('div');div.className=`si ${owned?'equipped':''}`;
      div.innerHTML=`<div class="si-icon">${item.icon}</div><div class="si-name">${item.name}</div><div class="si-desc">${item.desc}</div><div class="si-price ${!ca&&!owned?'cant':''}">${owned?'✓ Owned':item.price.toLocaleString()+'g'}</div>`;
      div.addEventListener('click',()=>{
        if(owned)return;
        if(S.gold<item.price){document.getElementById('shop-msg').textContent='Not enough gold!';return;}
        S.gold-=item.price;S.autoRodId=item.id;
        const interval=item.id==='autofish_god'?400:item.id==='autofish_ultra'?800:item.id==='autofish_elite'?1500:item.id==='autofish_fast'?3000:6000;
        if(S.autoFishing){clearInterval(S.autoInterval);S.autoInterval=setInterval(autoFishTick,interval);}
        updateHUD();renderShop();saveGame();toast(item.icon+' '+item.name+' purchased!');
      });
      grid.appendChild(div);
    });
  } else if(S.shopTab==='potions'){
    const wrap=document.createElement('div');
    wrap.style.cssText='display:grid;grid-template-columns:repeat(2,1fr);gap:8px;width:100%;';
    POTIONS.forEach(p=>{
      const ca=S.gold>=p.price;
      const pot=S.potions?.[p.type];
      const active=p.type==='all'?false:(pot?.active&&Date.now()<pot.endsAt);
      const rem=active?Math.round((pot.endsAt-Date.now())/1000):0;
      const d=document.createElement('div');
      d.className='potion-card'+(active?' pot-active':'');
      d.innerHTML=`<div class="pot-icon">${p.icon}</div><div class="pot-name">${p.name}</div><div class="pot-desc">${p.desc}</div><div class="pot-price${!ca&&!active?' cant':''}">${active?'✓ Active '+rem+'s':p.price.toLocaleString()+'g'}</div>`;
      if(!active)d.addEventListener('click',()=>{usePotion(p);renderShop();});
      wrap.appendChild(d);
    });
    grid.appendChild(wrap);
  }
}
function clickRod(r){
  if(S.ownedRods.includes(r.id)){S.currentRod=r.id;updateHUD();renderShop();toast(r.icon+' Equipped '+r.name+'!');return;}
  if(S.gold<r.price){document.getElementById('shop-msg').textContent='Not enough gold!';return;}
  S.gold-=r.price;S.ownedRods.push(r.id);S.currentRod=r.id;S.rodsOwned++;
  updateHUD();renderShop();saveGame();toast(r.icon+' '+r.name+' purchased!');
  checkBadges();
}
function clickBait(b){
  if(S.gold<b.price){document.getElementById('shop-msg').textContent='Not enough gold!';return;}
  S.gold-=b.price;S.baitInventory[b.id]=(S.baitInventory[b.id]||0)+b.qty;
  S.currentBait=b.id;updateHUD();renderShop();toast(b.icon+' '+b.name+' x'+b.qty+'!');
}

