let currentUser=null;
const OWNER='haerin';
const GEV_KEY='fisch_global_event';

function getGEV(){try{return JSON.parse(localStorage.getItem(GEV_KEY)||'null');}catch(e){return null;}}
function setGEV(type,dur){localStorage.setItem(GEV_KEY,JSON.stringify({type,dur,endsAt:Date.now()+dur*1000}));}
function clearGEV(){localStorage.removeItem(GEV_KEY);}

// Sync global event every 5s (shared across all users)
setInterval(()=>{
  const ge=getGEV();
  if(ge&&Date.now()<ge.endsAt){
    const rem=Math.round((ge.endsAt-Date.now())/1000);
    if(S.event!==ge.type){
      if(S.event)_endEventLocal();
      S.event=ge.type;S.eventTimer=rem;
      _applyEventVisuals(ge.type);
      showEvNotif(ge.type);
      playEvSound(ge.type);
    } else {
      S.eventTimer=rem;
    }
  } else if(ge&&Date.now()>=ge.endsAt){
    clearGEV();
    if(S.event)endEvent();
  }
  // Update admin panel active event display
  if(currentUser===OWNER){
    const gel=getGEV();
    const adel=document.getElementById('adm-active');
    if(adel){
      if(gel&&Date.now()<gel.endsAt){
        const rem=Math.round((gel.endsAt-Date.now())/1000);
        const ec=EVENTS[gel.type];
        adel.innerHTML=`<span class="adm-ev-tag" style="background:${ec?.color||'#ff8800'}22;color:${ec?.color||'#ff8800'};border:1px solid ${ec?.color||'#ff8800'}44">${ec?.icon||'?'} ${gel.type} — ${rem}s remaining</span>`;
      } else {
        adel.innerHTML='<span style="font-size:9px;color:var(--td);font-style:italic">No active global event</span>';
      }
    }
    const cg=document.getElementById('adm-cur-gold');
    if(cg)cg.textContent=S.gold.toLocaleString()+'g';
    const cl=document.getElementById('adm-cur-level');
    if(cl)cl.textContent='Lv.'+S.level+' ('+S.exp+'/'+getExpNeeded(S.level)+'exp)';
  }
},5000);

