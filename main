  {id:'s_blood2', name:'Blood Moon Totem ×2', icon:'🌑', desc:'Double pack',                 price:3500, type:'item2',  itemId:'bloodtotem', qty:2},
  {id:'s_aur2',   name:'Aurora Totem ×2',     icon:'🌈', desc:'Double pack',                 price:6000, type:'item2',  itemId:'auroratotem', qty:2},
];
// Also rod discount items (generated from RODS pool)
function buildShop15(){
  const seed=S.shopTimer;
  // pseudo-random from seed
  let s=seed;function sr(n){s=(s*16807)%2147483647;return Math.abs(s)%n;}
  // pick 8 items from pool
  const shuffled=[...SHOP_POOL].sort(()=>sr(3)-1.5);
  const picks=shuffled.slice(0,6);
  // pick 2 discounted rods
  const rods=RODS.filter(r=>!r.quest&&r.id!=='starter'&&r.price>0);
  const rod1=rods[sr(rods.length)], rod2=rods[sr(rods.length)];
  [rod1,rod2].forEach((r,i)=>picks.push({
    id:'s_rod_'+i, name:r.name+' (Sale!)', icon:r.icon,
    desc:'L'+r.luck+' C'+r.ctrl+' S'+r.str+' Spd'+r.spd,
    price:Math.round(r.price*(0.45+sr(30)/100)), type:'rod', rodId:r.id, origPrice:r.price,
  }));

  const grid=document.getElementById('daily-grid');grid.innerHTML='';
  const msgEl=document.getElementById('daily-msg');if(msgEl)msgEl.textContent='';

  // Timer display
  const msLeft=900000-(Date.now()%900000);
  const m=Math.floor(msLeft/60000),sec=Math.floor((msLeft%60000)/1000);
  const timerEl=document.getElementById('daily-timer');
  if(timerEl)timerEl.textContent=`Next refresh in: ${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;

  picks.forEach(item=>{
    const bought=S.shopPurchased[item.id];
    const ca=S.gold>=item.price;
    const div=document.createElement('div');div.className=`si daily-sp ${bought?'owned':''}`;
    const discLabel=item.origPrice?` <span style="color:var(--td);text-decoration:line-through;font-size:8px">${item.origPrice.toLocaleString()}g</span>`:'';
    div.innerHTML=`<div class="si-icon">${item.icon}</div><div class="si-name">${item.name}</div><div class="si-desc">${item.desc}</div><div class="si-price ${!ca&&!bought?'cant':''}">${bought?'✓ Bought':item.price.toLocaleString()+'g'}${discLabel}</div>`;
    if(!bought)div.addEventListener('click',()=>buyShopItem(item));
    grid.appendChild(div);
  });
  const any=picks.some(i=>!S.shopPurchased[i.id]);
  const badge=document.getElementById('daily-badge');if(badge)badge.style.display=any?'inline-block':'none';
}
function buyShopItem(item){
  if(S.gold<item.price){const el=document.getElementById('daily-msg');if(el)el.textContent='Not enough gold!';return;}
  S.gold-=item.price;S.shopPurchased[item.id]=true;
  if(item.type==='item'||item.type==='item2'){
    const qty=item.qty||1;S.items[item.itemId]=(S.items[item.itemId]||0)+qty;toast(item.icon+' '+item.name+' added to Items!');
  } else if(item.type==='bait'){
    S.baitInventory[item.baitId]=(S.baitInventory[item.baitId]||0)+item.baitQty;S.currentBait=item.baitId;toast(item.icon+' Bait added!');
  } else if(item.type==='rod'){
    if(!S.ownedRods.includes(item.rodId)){S.ownedRods.push(item.rodId);S.rodsOwned++;}S.currentRod=item.rodId;toast(item.icon+' '+item.name.replace(' (Sale!)','')+' purchased!');
  }
  updateHUD();buildShop15();saveGame();
}
setInterval(()=>{
  const msLeft=900000-(Date.now()%900000);
  const m=Math.floor(msLeft/60000),sec=Math.floor((msLeft%60000)/1000);
  const el=document.getElementById('daily-timer');
  if(el)el.textContent=`Next refresh in: ${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
},1000);

